  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "install:electron": "node node_modules/electron/install.js",
    "postinstall": "pnpm install:electron",
    "generate:preload": "ts-node ./electron/scripts/generate-preload.ts"
  },
  "dependencies": {
    "@iconify-json/radix-icons": "^1.2.6",
    "@iconify/vue": "^5.0.0",
    "@masscholar/i18n": "workspace:^",
    "@masscholar/ui": "workspace:^",
    "@vueuse/core": "^13.9.0",
    "electron-dl": "^4.0.0",
    "lucide-vue-next": "^0.536.0",
    "pinia": "^3.0.4",
    "reflect-metadata": "^0.2.2",
    "vue": "^3.5.31",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.19.15",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/eslint-plugin": "^1.6.13",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "chokidar": "^4.0.3",
    "electron": "^37.10.3",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "~10.3.0",
    "install": "^0.13.0",
    "jiti": "^2.6.1",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.6.2",
    "tailwindcss": "^4.2.2",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.3",
    "vite": "^7.3.1",
    "vite-plugin-doubleshot": "^0.0.18",
    "vite-plugin-vue-devtools": "^8.1.1",
