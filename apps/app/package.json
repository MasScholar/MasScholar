{
  "name": "@masscholar/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "install:electron": "node node_modules/electron/install.js",
    "postinstall": "pnpm install:electron",
    "generate:preload": "ts-node ./electron/scripts/generate-preload.ts"
  },
  "dependencies": {
    "@iconify-json/radix-icons": "^1.2.6",
    "@iconify/vue": "^5.0.0",
    "@masscholar/i18n": "workspace:^",
    "@masscholar/ui": "workspace:^",
    "@vueuse/core": "^14.2.1",
    "electron-dl": "^4.0.0",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "reflect-metadata": "^0.2.2",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/eslint-plugin": "^1.6.13",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "chokidar": "^5.0.0",
    "electron": "^41.1.0",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "~10.8.0",
    "install": "^0.13.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.8.1",
    "tailwindcss": "^4.2.2",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-doubleshot": "^0.0.21",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
